# AYY-27 — Django web service Dockerfile
# Multi-stage: builds, optionally compiles critical modules via Nuitka, runs gunicorn.
#
# STAGE 1: build
#   Install build deps, compile Nuitka extensions if NYUOTA_COMPILE=1
# STAGE 2: run
#   Minimal image with runtime deps only

ARG PYTHON_VERSION=3.12-slim-bookworm

# ── Stage 1: build ──
FROM python:${PYTHON_VERSION} AS build

RUN apt-get update && apt-get install -y --no-install-recommends \
        gcc \
        libpq-dev \
        python3-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /build

# Install Python deps first (cache layer optimization)
COPY pos_spike/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt 2>/dev/null || \
    pip install --no-cache-dir \
        django \
        djangorestframework \
        gunicorn \
        uvicorn \
        celery \
        django-celery-beat \
        redis \
        psycopg2-binary \
        requests \
        lxml \
        nuitka \
        hypothesis \
        coveralls \
        pytest

# Copy the full app source
COPY pos_spike/ /build/pos_spike/
COPY tally_spike/ /build/tally_spike/
COPY irp_spike/ /build/irp_spike/

# Optional Nuitka compilation of critical modules
ARG NYUOTA_COMPILE=0
RUN if [ "$NYUOTA_COMPILE" = "1" ]; then \
        python -m nuitka \
            --module \
            --standalone \
            --output-dir=/build/nuitka_out \
            --enable-plugin=django \
            pos_spike/sync_core/drainer.py \
            pos_spike/sync_core/cloud.py \
        && echo "Nuitka compilation complete" \
    ; else \
        echo "Skipping Nuitka (NYUOTA_COMPILE=0)"; \
    fi

# ── Stage 2: run ──
FROM python:${PYTHON_VERSION} AS run

RUN apt-get update && apt-get install -y --no-install-recommends \
        curl \
        libpq5 \
    && rm -rf /var/lib/apt/lists/* \
    && adduser --disabled-password --gecos '' appuser

WORKDIR /app

# Install runtime Python deps (same set, no build tools)
RUN pip install --no-cache-dir \
        django \
        djangorestframework \
        gunicorn \
        uvicorn \
        celery \
        django-celery-beat \
        redis \
        psycopg2-binary \
        requests \
        lxml

# Copy app source
COPY pos_spike/ /app/
COPY tally_spike/ /app/tally_spike/
COPY irp_spike/ /app/irp_spike/
COPY storebox/ /app/storebox/

# Copy Nuitka output if it exists
COPY --from=build /build/nuitka_out /app/nuitka_out 2>/dev/null || true

RUN chown -R appuser:appuser /app
USER appuser

EXPOSE 8000

CMD ["gunicorn", "conf.wsgi:application", "--bind", "0.0.0.0:8000", "--workers", "4", "--timeout", "120"]
