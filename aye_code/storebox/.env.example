# AYY-27 — Environment variables for the store box
# Copy to .env and adjust values for your environment.
# DO NOT commit actual .env files with secrets to version control.

# ── Store identity ──
STORE_ID=store-0001

# ── Django ──
DJANGO_SECRET_KEY=change-me-to-a-random-string
DJANGO_ENV=store

# ── Database ──
POSTGRES_PASSWORD=ayypos_secret

# ── Cloud API (for sync — set to cloud endpoint in production) ──
CLOUD_API_URL=http://localhost:8000

# ── Nginx ports (bind to specific interfaces in production) ──
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# ── Nuitka (1 = compile critical modules at build time) ──
NYUOTA_COMPILE=0
